# Django (Gunicorn) + static React build. Test backend: curl -sS -m 5 http://127.0.0.1:8002/api/
# If /api hangs: Gunicorn not running, wrong port, or host blocks mod_proxy in .htaccess (see OVH support).
# Gunicorn port: backend/start_gunicorn.sh (default 8002). Match it below.

Options -MultiViews

# Tell Django the browser used HTTPS (required for SECURE_PROXY_SSL_HEADER in production)
<IfModule mod_headers.c>
  RequestHeader set X-Forwarded-Proto "https" env=HTTPS
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Django — must use [P] (needs mod_proxy + mod_proxy_http + AllowOverride)
  RewriteCond %{REQUEST_URI} ^/(api|admin|static|media|swagger|redoc)(/|$) [NC]
  RewriteRule ^(.*)$ http://127.0.0.1:8002%{REQUEST_URI} [P,L,QSA]

  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
