# Match react/public/.htaccess — deploy copies react/dist/.htaccess to document root.

Options -MultiViews

<IfModule mod_headers.c>
  RequestHeader set X-Forwarded-Proto "https" env=HTTPS
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Legacy alias: Outils → Formules de déménagement lives at /tarif/
  RewriteRule ^tarification/?$ /tarif/ [R=301,L]

  RewriteCond %{REQUEST_URI} ^/(api|admin|static|media|swagger|redoc)(/|$) [NC]
  RewriteRule ^(.*)$ http://127.0.0.1:8002%{REQUEST_URI} [P,L,QSA]

  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
