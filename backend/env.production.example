#!/bin/bash
# Production environment for goyard-demenagement.fr
# On the server: cp env.production.example .env
# Then: chmod +x load_env.sh && source load_env.sh
#
# This file shows the expected KEY=VALUE format read by load_env.sh.
# Copy to .env and fill in real values.

# Django
DJANGO_SETTINGS_MODULE=core.settings.production
DJANGO_SECRET_KEY=change-me-to-a-real-secret-key

# MySQL/MariaDB Database Configuration
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_HOST=localhost
DB_PORT=3306

# Allowed hosts
ALLOWED_HOSTS=goyard-demenagement.fr,www.goyard-demenagement.fr

# CORS (no trailing slashes)
CORS_ALLOWED_ORIGINS=https://goyard-demenagement.fr,https://www.goyard-demenagement.fr

# Google Maps API key
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Gmail OAuth (for sending devis PDF by email)
GMAIL_SENDER_EMAIL=contact@guivarchedemenagement.fr
GMAIL_OAUTH_CLIENT_ID=your-gmail-oauth-client-id
GMAIL_OAUTH_CLIENT_SECRET=your-gmail-oauth-client-secret
GMAIL_OAUTH_REFRESH_TOKEN=your-gmail-oauth-refresh-token
GMAIL_OAUTH_TOKEN_URI=https://oauth2.googleapis.com/token
