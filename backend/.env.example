# Production Environment Variables Example
# Copy this file to .env and fill in your actual values

# Django Settings
DJANGO_SETTINGS_MODULE=core.settings.production
DJANGO_SECRET_KEY=your-very-secret-key-here-change-this-in-production

# Database Configuration
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_HOST=localhost
DB_PORT=3306

# Allowed Hosts (comma-separated) — add every production domain
ALLOWED_HOSTS=goyard-demenagement.fr,www.goyard-demenagement.fr,guivarche-demenagement.fr,www.guivarche-demenagement.fr

# CORS (comma-separated HTTPS origins)
CORS_ALLOWED_ORIGINS=https://goyard-demenagement.fr,https://www.goyard-demenagement.fr,https://guivarche-demenagement.fr,https://www.guivarche-demenagement.fr

# Optional: override CSRF trusted origins (defaults to CORS list if empty)
# CSRF_TRUSTED_ORIGINS=https://guivarche-demenagement.fr,https://www.guivarche-demenagement.fr

# Google Maps API Key
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# Gmail OAuth (for sending devis PDF by email)
GMAIL_SENDER_EMAIL=contact@guivarchedemenagement.fr
GMAIL_OAUTH_CLIENT_ID=your-gmail-oauth-client-id
GMAIL_OAUTH_CLIENT_SECRET=your-gmail-oauth-client-secret
GMAIL_OAUTH_REFRESH_TOKEN=your-gmail-oauth-refresh-token
GMAIL_OAUTH_TOKEN_URI=https://oauth2.googleapis.com/token

# Additional Settings (optional)
# DEBUG=False
# PYTHONPATH=/path/to/your/backend
