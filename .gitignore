# Environment / secrets
.env
backend/.env
backend/.env.*
!backend/.env.example
!backend/env.production.example

# Node (never commit dependencies — large; avoids Windows/OneDrive mmap errors on git add)
node_modules/
react/node_modules/
react/node_modules/.vite/

# Python
__pycache__/
*.py[cod]
*.pyo
*.venv/
.venv/
backend/**/.venv/

# Sonar issue reports (generated by scripts/sonar_analyze_and_report.py)
sonar-issues-report.md
sonar-issues.json

# Local AI uploads / training output (large; OneDrive can break `git add` with mmap errors)
backend/ai_detector/ai_model/images/original_imgs/
backend/ai_detector/ai_model/images/trained_imgs/
